            ee_goal_quat=current_ee_quat,
            label=f"return to {WAYPOINT_000_PATH}",
            tol=WAYPOINT_000_TOL,
        )

    async def _return_received_to_home(self):
        if self.received_robot is None:
            return False

        _prim(RECEIVED_HOME_PATH)

        current_pos, current_quat = _get_world_pose(RECEIVED_EE_LINK_PATH)
        home_pos, _ = _get_world_pose(RECEIVED_HOME_PATH)

        if self.received_home_ee_quat is None:
            self.received_home_ee_quat = _get_world_pose(RECEIVED_EE_LINK_PATH)[1].copy()

        # 1) 현재 위치에서 위로 retreat
        retreat_pos = current_pos + np.array([0.0, 0.0, RECEIVED_HOME_RETURN_LIFT_Z], dtype=np.float64)
        ok = await self._move_received_ee_goal(
            ee_goal_pos=retreat_pos,
            ee_goal_quat=current_quat,
            label="received retreat up",
            tol=RECEIVED_LINEAR_GRAP_01_TOL,
        )
        if not ok:
            return False

        # 2) home 위쪽 approach 위치로 이동 (현재 quat 유지)
        approach_pos = home_pos + np.array([0.0, 0.0, RECEIVED_HOME_RETURN_LIFT_Z], dtype=np.float64)
        ok = await self._move_received_ee_goal(
            ee_goal_pos=approach_pos,
            ee_goal_quat=current_quat,
            label="received move to home approach",
            tol=RECEIVED_LINEAR_GRAP_01_TOL,
        )
        if not ok:
            return False

        # 3) home 최종 위치 + 저장된 정상 standby quat로 정렬
        ok = await self._move_received_ee_goal(
            ee_goal_pos=home_pos,
            ee_goal_quat=self.received_home_ee_quat.copy(),
            label=f"return to {RECEIVED_HOME_PATH}",
            tol=RECEIVED_LINEAR_GRAP_01_TOL,
        )
        return ok

    async def _wait_and_delete_root(self, root_path: str, wait_sec: float, label: str):
        start = time.monotonic()
        while self.timeline.is_playing() and (time.monotonic() - start) < wait_sec:
            await asyncio.sleep(PHYSICS_DT)

        if not self.timeline.is_playing():
            return False

        _remove_prim_if_exists(root_path)
        return True

    async def _process_c_final(self):
