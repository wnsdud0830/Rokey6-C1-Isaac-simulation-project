            self.task = asyncio.ensure_future(self.run())

    def shutdown(self):
        if self.task and not self.task.done():
            self.task.cancel()
        self.task = None

        if self.giving_return_task and not self.giving_return_task.done():
            self.giving_return_task.cancel()
        self.giving_return_task = None

        if self.timeline_sub is not None:
            try:
                self.timeline_sub.unsubscribe()
            except Exception:
                pass
        self.timeline_sub = None

        _cleanup_temp_objects()

        self.giving_robot = None
        self.giving_rmpflow = None
        self.giving_articulation_rmpflow = None
        self.giving_gripper = None

        self.received_robot = None
        self.received_rmpflow = None
        self.received_articulation_rmpflow = None

        self.giving_follow_active = False
        self.received_follow_active = False
        self.mesh_move_active = False

    def _on_timeline_event(self, event):
        etype = event.type

        if etype == omni.timeline.TimelineEventType.PLAY.value:
            if self.task is None or self.task.done():
                self.task = asyncio.ensure_future(self.run())

        elif etype == omni.timeline.TimelineEventType.STOP.value:
            self.giving_follow_active = False
            self.received_follow_active = False
            self.mesh_move_active = False

            if self.task and not self.task.done():
                self.task.cancel()
            self.task = None

            if self.giving_return_task and not self.giving_return_task.done():
                self.giving_return_task.cancel()
            self.giving_return_task = None

            _cleanup_temp_objects()

        elif etype == omni.timeline.TimelineEventType.PAUSE.value:
            if self.task and not self.task.done():
                self.task.cancel()
            self.task = None

            if self.giving_return_task and not self.giving_return_task.done():
                self.giving_return_task.cancel()
            self.giving_return_task = None

    async def _wait_for_required_prims(self):
        await asyncio.sleep(PRECHECK_INITIAL_DELAY_SEC)

        for _ in range(PRECHECK_RETRY_COUNT):
            if not self.timeline.is_playing():
                return False

            try:
                _resolve_runtime_paths()
                required = [
                    GIVING_ROBOT_ROOT,
                    GIVING_EE_LINK_PATH,
                    GIVING_GRIPPER_TIP_PATH,
                    GIVING_SURFACE_GRIPPER_PATH,
                    RECEIVED_ROBOT_ROOT,
                    RECEIVED_EE_LINK_PATH,
                    RECEIVED_GRIPPER_TIP_PATH,
                    WAYPOINT_000_PATH,
                    WAYPOINT_01_PATH,
                    WAYPOINT_001_PATH,
                    PLACE_FOR_A_PATH,
                    PLACE_FOR_B_PATH,
                    PLACE_FOR_C_PATH,
                    GIVING_CAMERA_PATH,
                    RECEIVED_CAMERA_PATH,
                    RECEIVED_HOME_PATH,
                    GIVING_REMOVE_BOTTLE_XFORM_PATH,
                    GIVING_SPAWN_BOTTLE_XFORM_PATH,
                    MOVE_DONE_XFORM_PATH,
                    RECEIVED_LINEAR_MOVE_01_PATH,
                    RECEIVED_LINEAR_GRAP_01_PATH,
                    RECEIVED_LINEAR_GRAP_03_PATH,
                    RECEIVED_LINEAR_GRAP_04_PATH,
                ]
                if not [p for p in required if not _has_prim(p)]:
                    return True
            except Exception:
                pass

            await asyncio.sleep(PRECHECK_RETRY_INTERVAL_SEC)

        return False

    def _load_rmp_config(self):
        return load_supported_motion_policy_config("UR10", "RMPflow")

    async def _ensure_runtime_ready(self):
        _prim(GIVING_ROBOT_ROOT)
        _prim(GIVING_EE_LINK_PATH)
        _prim(GIVING_GRIPPER_TIP_PATH)
        _prim(GIVING_SURFACE_GRIPPER_PATH)

        _prim(RECEIVED_ROBOT_ROOT)
        _prim(RECEIVED_EE_LINK_PATH)
        _prim(RECEIVED_GRIPPER_TIP_PATH)

        _prim(WAYPOINT_000_PATH)
        _prim(WAYPOINT_01_PATH)
        _prim(WAYPOINT_001_PATH)
        _prim(PLACE_FOR_A_PATH)
        _prim(PLACE_FOR_B_PATH)
        _prim(PLACE_FOR_C_PATH)
        _prim(GIVING_CAMERA_PATH)
        _prim(RECEIVED_CAMERA_PATH)
        _prim(RECEIVED_HOME_PATH)

        if self.giving_robot is None:
            self.giving_robot = SingleArticulation(
                prim_path=GIVING_ROBOT_ROOT,
                name="ur10_giving_robot",
            )
            self.giving_robot.initialize()

        if self.giving_rmpflow is None:
            cfg = self._load_rmp_config()
            self.giving_rmpflow = RmpFlow(**cfg)
            self.giving_articulation_rmpflow = ArticulationMotionPolicy(
                self.giving_robot, self.giving_rmpflow
            )

        if self.giving_gripper is None:
            self.giving_gripper = SurfaceGripper(
                end_effector_prim_path=GIVING_EE_LINK_PATH,
                surface_gripper_path=GIVING_SURFACE_GRIPPER_PATH,
            )
            self.giving_gripper.initialize(articulation_num_dofs=self.giving_robot.num_dof)
            self.giving_gripper.open()

        if self.received_robot is None:
            self.received_robot = SingleArticulation(
                prim_path=RECEIVED_ROBOT_ROOT,
                name="ur10_received_robot",
            )
            self.received_robot.initialize()

        if self.received_rmpflow is None:
            cfg = self._load_rmp_config()
            self.received_rmpflow = RmpFlow(**cfg)
            self.received_articulation_rmpflow = ArticulationMotionPolicy(
                self.received_robot, self.received_rmpflow
            )

        await asyncio.sleep(PHYSICS_DT * 2)

        if self.received_home_ee_quat is None:
            self.received_home_ee_quat = _get_world_pose(RECEIVED_EE_LINK_PATH)[1].copy()

    async def _move_giving_ee_goal(self, ee_goal_pos, ee_goal_quat, label, tol):
        start = time.monotonic()

        while self.timeline.is_playing():
            robot_base_pos, robot_base_quat = self.giving_robot.get_world_pose()
            self.giving_rmpflow.set_robot_base_pose(robot_base_pos, robot_base_quat)
            self.giving_rmpflow.update_world()
            self.giving_rmpflow.set_end_effector_target(ee_goal_pos, ee_goal_quat)

            action = self.giving_articulation_rmpflow.get_next_articulation_action(PHYSICS_DT)
