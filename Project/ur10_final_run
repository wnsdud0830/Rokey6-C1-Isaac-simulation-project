    def _best_effort_enable_physics(self, root_path: str):
        root_prim = _prim(root_path)

        rb = UsdPhysics.RigidBodyAPI.Apply(root_prim)
        try:
            rb.CreateKinematicEnabledAttr(False)
        except Exception:
            pass

        try:
            rb.CreateStartsAsleepAttr(False)
        except Exception:
            pass

        for prim in Usd.PrimRange(root_prim):
            try:
                if prim.IsA(UsdGeom.Mesh):
                    UsdPhysics.CollisionAPI.Apply(prim)
            except Exception:
                pass

