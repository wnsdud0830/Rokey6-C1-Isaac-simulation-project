    async def _process_ab_received_pipeline(self, downstream_root: str, giving_detected_type: str):
        if not _has_prim(downstream_root):
            raise RuntimeError(f"Downstream bottle root missing: {downstream_root}")

        await asyncio.sleep(RECEIVED_QR_WAIT_AFTER_STOP_SEC)

        received_detected_type = await self._detect_bottle_type_from_camera(
            RECEIVED_CAMERA_PATH,
            fallback_type=giving_detected_type,
            log_label="received_qr",
        )
        self.last_received_detected_type = received_detected_type

        ok = await self._move_mesh_to_xform(
            downstream_root,
            RECEIVED_LINEAR_MOVE_01_PATH,
            tol=RECEIVED_LINEAR_MOVE_01_TOL,
            speed_mps=max(CONVEYOR_SPEED_MPS, 0.10),
            label="move bottle from move_done to linear_move_01",
        )
        if not ok:
            return False

        ok = await self._move_received_to_xform_keep_current_quat(
            RECEIVED_LINEAR_GRAP_01_PATH,
            label=f"move received robot to {RECEIVED_LINEAR_GRAP_01_PATH}",
            tol=RECEIVED_LINEAR_GRAP_01_TOL,
        )
        if not ok:
            return False

        _remove_prim_if_exists(downstream_root)

        self._spawn_temp_received_bottle_attached_to_tip(received_detected_type)
        await asyncio.sleep(HOLD_AFTER_ATTACH_SEC)

        if received_detected_type == "A":
            final_place_path = PLACE_FOR_A_PATH
            final_tol = PLACE_FOR_A_TOL
        elif received_detected_type == "B":
            final_place_path = PLACE_FOR_B_PATH
            final_tol = PLACE_FOR_B_TOL
        else:
            raise RuntimeError(f"Received stage only expects A/B, got {received_detected_type}")

        grap03_pos, _ = _get_world_pose(RECEIVED_LINEAR_GRAP_03_PATH)
        carry_quat = _get_world_pose(RECEIVED_EE_LINK_PATH)[1]
        ok = await self._move_received_ee_goal(
            ee_goal_pos=grap03_pos,
            ee_goal_quat=carry_quat,
            label=f"carry received bottle via {RECEIVED_LINEAR_GRAP_03_PATH}",
            tol=RECEIVED_LINEAR_GRAP_01_TOL,
        )
        if not ok:
            return False

        grap04_pos, _ = _get_world_pose(RECEIVED_LINEAR_GRAP_04_PATH)
        carry_quat = _get_world_pose(RECEIVED_EE_LINK_PATH)[1]
        ok = await self._move_received_ee_goal(
            ee_goal_pos=grap04_pos,
            ee_goal_quat=carry_quat,
            label=f"carry received bottle via {RECEIVED_LINEAR_GRAP_04_PATH}",
            tol=RECEIVED_LINEAR_GRAP_01_TOL,
        )
        if not ok:
            return False

        final_place_pos, _ = _get_world_pose(final_place_path)
        carry_quat = _get_world_pose(RECEIVED_EE_LINK_PATH)[1]
        ok = await self._move_received_ee_goal(
            ee_goal_pos=final_place_pos,
            ee_goal_quat=carry_quat,
            label=f"carry received bottle to {final_place_path}",
            tol=final_tol,
        )
        if not ok:
            return False

        self._detach_temp_received_bottle_in_place()

        ok = await self._return_received_to_home()
        if not ok:
            return False

        ok = await self._wait_and_delete_root(
            TEMP_RECEIVED_BOTTLE_ROOT_PATH,
            FINAL_DELETE_WAIT_SEC,
            label=f"final {received_detected_type} bottle",
        )
        if not ok:
            return False

        return True

    async def run(self):
        try:
            while not self.timeline.is_playing():
                await asyncio.sleep(0.1)

            ok = await self._wait_for_required_prims()
            if not ok:
                return

            await self._ensure_runtime_ready()
            _cleanup_stale_joints()
            _cleanup_temp_objects()

            cycle_index = 0

            while self.timeline.is_playing():
                cycle_index += 1
                _important_print(f"[MASTER] Cycle start: {cycle_index}")

                await asyncio.sleep(DELAY_BEFORE_MOVE_SEC)

                if not self.timeline.is_playing():
                    return

                self.selected_bottle_type = None
                self.selected_bottle_usd_path = None
                self.last_giving_detected_type = None
                self.last_received_detected_type = None
                self.giving_follow_active = False
                self.received_follow_active = False
                self.mesh_move_active = False

                if self.giving_return_task and not self.giving_return_task.done():
                    self.giving_return_task.cancel()
                self.giving_return_task = None

                _cleanup_temp_objects()

                ok = await self._move_giving_to_xform_keep_current_quat(
                    WAYPOINT_000_PATH,
                    label=f"move to {WAYPOINT_000_PATH}",
                    tol=WAYPOINT_000_TOL,
                )
                if not ok:
                    return

                await self._close_giving_gripper_and_settle()
                self._spawn_temp_giving_bottle_attached_to_tip()
                await asyncio.sleep(HOLD_AFTER_ATTACH_SEC)

                carry_quat = _get_world_pose(GIVING_EE_LINK_PATH)[1]
                wp01_pos, _ = _get_world_pose(WAYPOINT_01_PATH)
                ok = await self._move_giving_ee_goal(
                    ee_goal_pos=wp01_pos,
                    ee_goal_quat=carry_quat,
                    label=f"carry temp bottle to {WAYPOINT_01_PATH}",
                    tol=WAYPOINT_01_TOL,
                )
                if not ok:
                    return

                self.wp01_pick_quat = _get_world_pose(GIVING_EE_LINK_PATH)[1].copy()

                self._detach_temp_giving_bottle_in_place()

                ok = await self._move_giving_to_xform_keep_current_quat(
                    WAYPOINT_001_PATH,
                    label=f"move to {WAYPOINT_001_PATH} for clear camera view",
                    tol=WAYPOINT_001_TOL,
                )
                if not ok:
                    return

                await asyncio.sleep(GIVING_QR_WAIT_AFTER_CLEAR_VIEW_SEC)

                giving_detected_type = await self._detect_bottle_type_from_camera(
                    GIVING_CAMERA_PATH,
                    fallback_type=self.selected_bottle_type,
                    log_label="giving_qr",
                )
                self.last_giving_detected_type = giving_detected_type

                if giving_detected_type not in ["A", "B", "C"]:
                    raise RuntimeError(f"Unexpected detected bottle type: {giving_detected_type}")

                if giving_detected_type in ["A", "B"]:
                    ok = await self._move_giving_to_wp01_with_saved_pick_quat(
                        label=f"return to {WAYPOINT_01_PATH} for re-pick",
                        tol=WAYPOINT_01_TOL,
                    )
                    if not ok:
                        return

                    await self._close_giving_gripper_and_settle()
                    self._attach_existing_temp_giving_bottle_to_tip()

                    carry_quat = _get_world_pose(GIVING_EE_LINK_PATH)[1]
                    remove_pos, _ = _get_world_pose(GIVING_REMOVE_BOTTLE_XFORM_PATH)
                    ok = await self._move_giving_ee_goal(
                        ee_goal_pos=remove_pos,
                        ee_goal_quat=carry_quat,
                        label=f"carry detected {giving_detected_type} bottle to {GIVING_REMOVE_BOTTLE_XFORM_PATH}",
                        tol=GIVING_REMOVE_POS_TOL,
                    )
                    if not ok:
                        return

                    self._delete_temp_giving_bottle()

                    downstream_root = self._next_unique_root("/Root/output_bottle_ab")
                    self._spawn_bottle_at_xform(
                        downstream_root,
                        GIVING_SPAWN_BOTTLE_XFORM_PATH,
                        self.selected_bottle_usd_path,
                    )

                    if RETURN_GIVING_TO_WP000:
                        if self.giving_return_task and not self.giving_return_task.done():
                            self.giving_return_task.cancel()
                        self.giving_return_task = asyncio.ensure_future(self._return_giving_to_wp000())

                    ok = await self._move_mesh_until_stop(
                        downstream_root,
                        MOVE_DONE_XFORM_PATH,
                    )
                    if not ok:
                        return

                    if RETURN_GIVING_TO_WP000 and self.giving_return_task is not None:
                        await self.giving_return_task

                    ok = await self._process_ab_received_pipeline(
                        downstream_root=downstream_root,
                        giving_detected_type=giving_detected_type,
                    )
                    if not ok:
                        return

                else:
                    ok = await self._move_giving_to_wp01_with_saved_pick_quat(
                        label=f"return to {WAYPOINT_01_PATH} for re-pick C",
                        tol=WAYPOINT_01_TOL,
                    )
                    if not ok:
                        return

                    await self._close_giving_gripper_and_settle()
                    self._attach_existing_temp_giving_bottle_to_tip()

                    carry_quat = _get_world_pose(GIVING_EE_LINK_PATH)[1]
                    place_c_pos, _ = _get_world_pose(PLACE_FOR_C_PATH)
                    ok = await self._move_giving_ee_goal(
                        ee_goal_pos=place_c_pos,
                        ee_goal_quat=carry_quat,
                        label=f"carry detected C bottle to {PLACE_FOR_C_PATH}",
                        tol=PLACE_FOR_C_TOL,
                    )
                    if not ok:
                        return

                    self._detach_temp_giving_bottle_in_place()

                    ok = await self._process_c_final()
                    if not ok:
                        return

                await asyncio.sleep(CYCLE_IDLE_SEC)

        except asyncio.CancelledError:
            pass
        except Exception:
            pass
        finally:
            self.giving_follow_active = False
            self.received_follow_active = False
            self.mesh_move_active = False
            self.task = None


_shutdown_known_controllers()
_cleanup_temp_objects()
globals()[CURRENT_CONTROLLER_NAME] = PhaseMasterGivingReceivedV23()
print("[MASTER] Ready")
