def _stage():
    stage = omni.usd.get_context().get_stage()
    if stage is None:
        raise RuntimeError("No USD stage is open.")
    return stage


def _prim(path):
    prim = _stage().GetPrimAtPath(path)
    if not prim.IsValid():
        raise RuntimeError(f"Invalid prim path: {path}")
    return prim


def _has_prim(path):
    return _stage().GetPrimAtPath(path).IsValid()


def _remove_prim_if_exists(path):
    prim = _stage().GetPrimAtPath(path)
    if prim.IsValid():
        _stage().RemovePrim(path)
        print(f"[CLEANUP] Removed: {path}")


def _get_world_pose(path):
    prim = _prim(path)
    mat = omni.usd.get_world_transform_matrix(prim)
    t = mat.ExtractTranslation()
    q = mat.ExtractRotationQuat()

    pos = np.array([float(t[0]), float(t[1]), float(t[2])], dtype=np.float64)
    quat_wxyz = np.array(
        [
            float(q.GetReal()),
            float(q.GetImaginary()[0]),
            float(q.GetImaginary()[1]),
            float(q.GetImaginary()[2]),
        ],
        dtype=np.float64,
    )
    return pos, quat_wxyz


def _set_xform_srt(prim, translate=None, rotate_xyz=None, scale=None):
    xform = UsdGeom.Xformable(prim)
    xform.ClearXformOpOrder()

    if translate is not None:
        xform.AddTranslateOp().Set(Gf.Vec3d(*translate))
    if rotate_xyz is not None:
        xform.AddRotateXYZOp().Set(Gf.Vec3f(*rotate_xyz))
    if scale is not None:
        xform.AddScaleOp().Set(Gf.Vec3f(*scale))


def _normalize(v):
    n = np.linalg.norm(v)
    if n < 1e-12:
        return v.copy()
    return v / n


def _quat_mul(q1, q2):
    w1, x1, y1, z1 = q1
    w2, x2, y2, z2 = q2
    return np.array(
        [
            w1 * w2 - x1 * x2 - y1 * y2 - z1 * z2,
            w1 * x2 + x1 * w2 + y1 * z2 - z1 * y2,
            w1 * y2 - x1 * z2 + y1 * w2 + z1 * x2,
            w1 * z2 + x1 * y2 - y1 * x2 + z1 * w2,
        ],
        dtype=np.float64,
    )


def _quat_conj(q):
    return np.array([q[0], -q[1], -q[2], -q[3]], dtype=np.float64)


def _rotate_vec(q, v):
    q = _normalize(q)
    vq = np.array([0.0, v[0], v[1], v[2]], dtype=np.float64)
    return _quat_mul(_quat_mul(q, vq), _quat_conj(q))[1:]


def _list_root_children():
    root = _stage().GetPrimAtPath("/Root")
    children = []
    if root.IsValid():
        for child in root.GetChildren():
            children.append(child.GetPath().pathString)
    return children


def _resolve_first_valid_path(candidates, label):
    stage = _stage()
    for path in candidates:
        if stage.GetPrimAtPath(path).IsValid():
            print(f"[PATH] {label} = {path}")
            return path
    raise RuntimeError(f"{label} not found. tried={candidates}")


def _cleanup_stale_joints():
    stage = _stage()

    for path in STALE_JOINT_HINTS:
        _remove_prim_if_exists(path)

    to_remove = []
    for prim in stage.Traverse():
        if "Joint" not in prim.GetTypeName():
            continue

        bad = False
        for rel_name in ["physics:body0", "physics:body1"]:
            rel = prim.GetRelationship(rel_name)
            if not rel:
                continue
            for tgt in rel.GetTargets():
                tgt_prim = stage.GetPrimAtPath(tgt)
                if not tgt_prim.IsValid():
                    bad = True
                    break
            if bad:
                break

        if bad:
            to_remove.append(prim.GetPath().pathString)

    for path in to_remove:
        _remove_prim_if_exists(path)


def _cleanup_temp_objects():
    _remove_prim_if_exists(ATTACH_JOINT_PATH)
    _remove_prim_if_exists(TEMP_GIVING_BOTTLE_ROOT_PATH)
    _remove_prim_if_exists(TEMP_RECEIVED_BOTTLE_ROOT_PATH)


