    async def _move_mesh_until_stop(self, root_path: str, stop_xform_path: str):
        if not _has_prim(root_path):
            return False

        self.mesh_move_active = True

        while self.timeline.is_playing() and self.mesh_move_active and _has_prim(root_path):
            root_prim = _prim(root_path)
            cur_pos, _ = _get_world_pose(root_path)
            next_pos = cur_pos + self.mesh_move_velocity * PHYSICS_DT

            _set_xform_srt(
                root_prim,
                translate=(float(next_pos[0]), float(next_pos[1]), float(next_pos[2])),
                rotate_xyz=BOTTLE_ROT,
                scale=BOTTLE_SCALE,
            )

            stop_pos, _ = _get_world_pose(stop_xform_path)
            err = np.linalg.norm(next_pos - stop_pos)

            if err <= MOVE_DONE_POS_TOL:
                self.mesh_move_active = False
                return True

            await asyncio.sleep(PHYSICS_DT)

        return False

    async def _move_mesh_to_xform(
        self,
        root_path: str,
        target_xform_path: str,
        tol: float,
        speed_mps: float,
        label: str,
    ):
        if not _has_prim(root_path):
            return False

        while self.timeline.is_playing() and _has_prim(root_path):
            root_prim = _prim(root_path)
            cur_pos, _ = _get_world_pose(root_path)
            tgt_pos, _ = _get_world_pose(target_xform_path)

            diff = tgt_pos - cur_pos
            err = np.linalg.norm(diff)

            if err <= tol:
                return True

            step = min(speed_mps * PHYSICS_DT, err)
            move_dir = _normalize(diff)
            next_pos = cur_pos + move_dir * step

            _set_xform_srt(
                root_prim,
                translate=(float(next_pos[0]), float(next_pos[1]), float(next_pos[2])),
                rotate_xyz=BOTTLE_ROT,
                scale=BOTTLE_SCALE,
            )

            await asyncio.sleep(PHYSICS_DT)

        return False

    async def _capture_camera_to_file(self, camera_path: str, out_path: str):
        _prim(camera_path)

        viewport = get_active_viewport()
        if viewport is None:
            raise RuntimeError("Active viewport not found.")

        old_camera = viewport.camera_path

        try:
            if os.path.exists(out_path):
                os.remove(out_path)

            viewport.camera_path = camera_path
            await omni.kit.app.get_app().next_update_async()
            await asyncio.sleep(QR_CAPTURE_WAIT_SEC)
            await omni.kit.app.get_app().next_update_async()

            capture_viewport_to_file(viewport, out_path)

            timeout = time.monotonic() + 5.0
            while time.monotonic() < timeout:
                if os.path.exists(out_path) and os.path.getsize(out_path) > 0:
                    return
                await asyncio.sleep(0.05)
                await omni.kit.app.get_app().next_update_async()

            raise RuntimeError(f"Capture file was not created: {out_path}")

        finally:
            try:
                viewport.camera_path = old_camera
                await omni.kit.app.get_app().next_update_async()
            except Exception:
                pass

    async def _wait_external_qr_result(self, timeout_sec: float):
        start = time.monotonic()
        last_payload = None

        while time.monotonic() - start <= timeout_sec:
            if os.path.exists(QR_RESULT_PATH):
                try:
                    with open(QR_RESULT_PATH, "r", encoding="utf-8") as f:
                        payload = json.load(f)
                    last_payload = payload

                    if payload.get("ok") is True and payload.get("detected_type") in ["A", "B", "C"]:
                        return payload["detected_type"]

                except Exception:
                    pass

            await asyncio.sleep(QR_RESULT_POLL_SEC)

        raise RuntimeError(f"External QR result timeout. last_payload={last_payload}")

    async def _detect_bottle_type_from_camera(self, camera_path: str, fallback_type=None, log_label="qr"):
        _clear_qr_result_files()

        try:
            await self._capture_camera_to_file(camera_path, QR_IMAGE_PATH)
            detected_type = await self._wait_external_qr_result(QR_RESULT_WAIT_SEC)

            if detected_type not in ["A", "B", "C"]:
                raise RuntimeError(f"Unexpected detected type: {detected_type}")

            return detected_type

        except Exception:
            if QR_FAIL_USE_SELECTED_TYPE:
                fallback = self._get_fallback_bottle_type(explicit_fallback=fallback_type)
                if fallback in ["A", "B", "C"]:
                    return fallback
            raise

    async def _return_giving_to_wp000(self):
        if self.giving_robot is None:
            return False

        _prim(WAYPOINT_000_PATH)

        if RETURN_GIVING_OPEN_GRIPPER and self.giving_gripper is not None:
            self.giving_gripper.open()

        pos, _ = _get_world_pose(WAYPOINT_000_PATH)
        current_ee_quat = _get_world_pose(GIVING_EE_LINK_PATH)[1]

        return await self._move_giving_ee_goal(
